# Single source of truth for the non-vLLM executables the llm-d-vllm
# framework needs (EPP, P/D sidecar, Envoy).
#
# This file is used by benchmarks/llm-d/extract-binaries.sh .
# It pulls each image once and copies the binary out to $LLMD_BIN_DIR 
# (mounted into the container at runtime by job.slurm).
#
# Note: benchmarks/llm-d/Dockerfile  uses the same URLs when using
# COPY --from build args
#
# This is currently not used as we build an use an image that contains 
# all binaries

# --- Endpoint Picker (EPP / inference scheduler) ---
EPP_FROM_IMAGE="ghcr.io/llm-d/llm-d-router-endpoint-picker-dev:main"
EPP_BIN_PATH="/app/epp"

# --- P/D routing sidecar (pd-sidecar) ---
ROUTING_SIDECAR_IMAGE="ghcr.io/llm-d/llm-d-router-disagg-sidecar-dev:main"
ROUTING_SIDECAR_BIN_PATH="/app/pd-sidecar"

# --- Envoy front proxy ---
ENVOY_FROM_IMAGE="envoyproxy/envoy:distroless-v1.33.2"
ENVOY_BIN_PATH="/usr/local/bin/envoy"

# Platform the binaries must target (GB200 = Grace = arm64).
LLMD_BIN_PLATFORM="${LLMD_BIN_PLATFORM:-linux/arm64}"

# Shared-filesystem dir the extracted binaries live in, mounted into
# /usr/local/bin by job.slurm. Defaults to the same Lustre area the
# launcher already caches enroot squash images in (proven writable).
LLMD_BIN_DIR="${LLMD_BIN_DIR:-/mnt/lustre01/users-public/sa-shared/llm-d-bins}"
