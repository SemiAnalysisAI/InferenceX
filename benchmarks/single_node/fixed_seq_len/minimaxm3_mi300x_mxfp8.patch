+        + offs_n[:, None] * stride_bn
+        + offs_k[None, :] * stride_bk
     )
+    bs_ptrs = b_scale_ptr + off_e * stride_bse + offs_n * stride_bsn
+
+    acc = tl.zeros((BLOCK_M, BLOCK_N), dtype=tl.float32)
+    n_mask = offs_n < N
+    if SPLIT_K == 1:
