+    tl.store(
+        aq_ptr + safe_route_ids[:, None] * stride_qm + offs_c[None, :] * stride_qn,
+        aq,
+        mask=route_mask[:, None],
+    )
+    tl.store(
+        as_ptr + safe_route_ids * stride_sm + pid_b * stride_sk,
+        sb.to(tl.uint8),
+        mask=route_mask,
+    )
