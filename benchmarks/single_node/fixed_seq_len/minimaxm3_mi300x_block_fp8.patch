+def requantize_mxfp8_to_block_fp8_(
+    weight: torch.Tensor,
+    scales: torch.Tensor,
+    block_size: tuple[int, int] = (128, 128),
+) -> tuple[torch.Tensor, torch.Tensor]:
+    """Convert MXFP8 weights in-place to native block FP8.
+
+    The returned weight aliases the one-byte checkpoint storage. Conversion is
+    matrix-by-matrix so the peak temporary is one BF16 expert, not an expanded
+    copy of the whole MoE layer.
+    """
+    from vllm.platforms import current_platform
+    from vllm.utils.deep_gemm import per_block_cast_to_fp8
+
+    if weight.dtype != MXFP8_VALUE_DTYPE:
+        raise ValueError(f"Expected MXFP8 weight dtype {MXFP8_VALUE_DTYPE}.")
+    if scales.dtype != MXFP8_SCALE_DTYPE:
+        raise ValueError(f"Expected MXFP8 scale dtype {MXFP8_SCALE_DTYPE}.")
+    if weight.ndim < 2:
+        raise ValueError("MXFP8 block-FP8 conversion requires a matrix.")
+    if not weight.is_contiguous() or not scales.is_contiguous():
+        raise ValueError("MXFP8 weight and scales must be contiguous.")
+
+    n, k = weight.shape[-2:]
+    if k % MXFP8_BLOCK_SIZE != 0:
+        raise ValueError(
+            f"MXFP8 K dimension must be divisible by {MXFP8_BLOCK_SIZE}, got {k}."
+        )
+    expected_scale_shape = (*weight.shape[:-1], k // MXFP8_BLOCK_SIZE)
+    if tuple(scales.shape) != expected_scale_shape:
+        raise ValueError(
+            "MXFP8 scale shape mismatch: expected "
+            f"{expected_scale_shape}, got {tuple(scales.shape)}."
+        )
+
+    block_n, block_k = block_size
+    matrix_count = weight.numel() // (n * k)
+    source = weight.detach().reshape(matrix_count, n, k)
+    source_scales = scales.detach().reshape(matrix_count, n, k // MXFP8_BLOCK_SIZE)
+    target = (
+        weight.detach().view(current_platform.fp8_dtype()).reshape(matrix_count, n, k)
+    )
+    target_scales = torch.empty(
+        (
+            matrix_count,
+            (n + block_n - 1) // block_n,
+            (k + block_k - 1) // block_k,
+        ),
+        dtype=torch.float32,
+        device=weight.device,
+    )
+
+    with torch.no_grad():
+        for matrix_id in range(matrix_count):
+            dequantized = dequant_mxfp8_to_bf16(
+                source[matrix_id], source_scales[matrix_id]
+            )
+            quantized, block_scales = per_block_cast_to_fp8(
+                dequantized,
+                block_size=[block_n, block_k],
+                use_ue8m0=False,
+            )
+            target[matrix_id].copy_(quantized)
+            target_scales[matrix_id].copy_(block_scales)
+
+    return target.view(weight.shape), target_scales.view(
+        *weight.shape[:-2], target_scales.shape[-2], target_scales.shape[-1]
+    )
+
+
