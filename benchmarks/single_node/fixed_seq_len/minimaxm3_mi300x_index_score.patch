+        is_init = block_id < init_blocks
+        is_local = (block_id >= local_start) & (block_id < num_blocks)
+        score = tl.where(is_local, 1e29, tl.where(is_init, 1e30, score))
+        tl.store(
+            score_ptr + request_id * stride_s_n + block_id * stride_s_k,
+            score,
+        )
